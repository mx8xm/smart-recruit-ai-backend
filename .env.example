APP_NAME="Smart Recruit AI"
VERSION="1.0.0"
DEBUG=True
DATABASE_URL=postgresql+asyncpg://user:password123@localhost:5432/smart_recruit_db
SECRET_KEY=CHANGE_ME_LOCAL_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=1000
GLINER_MODEL=urchade/gliner_multi-v2.1
SCORING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
ACCEPTANCE_THRESHOLD=0.45
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://tauri.localhost
HF_HOME=./.cache
TRANSFORMERS_CACHE=./.cache
SENTENCE_TRANSFORMERS_HOME=./.cache
TORCH_HOME=./.cache
AUTO_CREATE_TABLES=True
